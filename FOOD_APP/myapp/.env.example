# Host ports
# Standalone production can publish HTTP_PORT=80.
# If this runs on the same VPS as another nginx-managed service, keep this on
# loopback and proxy from the host nginx, e.g. HTTP_PORT=127.0.0.1:8081.
HTTP_PORT=80
BACKEND_PORT=8787
BACKEND_BIND=127.0.0.1
CORS_ORIGIN=

# Required for public write endpoints such as /api/config,
# /api/store-registration/metadata, and /api/accounts/set_password.
# Use a long random value on VPS. Do not commit the real value.
ADMIN_API_TOKEN=

# Public VPS mode. true disables backend keyring APIs and server-side signing.
# Transactions are signed in the browser with Keplr and only broadcast by backend.
KEYLESS_MODE=true

# Injective CLI container used by the backend when it runs docker commands.
INJ_IMAGE=injective-ubuntu:latest

# Optional. Leave empty on public VPS to avoid placing important keys on the server.
# Needed only for local server-side signing/deploy workflows with KEYLESS_MODE=false.
INJ_HOME_HOST_PATH=

# Keyring and account defaults
KEYNAME=
KEYRING_BACKEND=test
MY_ADDR=

# Injective network
INJ_NODE=https://testnet.sentry.tm.injective.network:443
INJ_LCD_REST=https://testnet.sentry.lcd.injective.network:443
INJ_CHAIN_ID=injective-888

# Deployed contract defaults used by the UI/backend.
CODE_ID=
CONTRACT=

# Host path to the optimized wasm used by /api/tx/store-code and /api/tx/deploy.
# Leave empty on public VPS. Use only with KEYLESS_MODE=false in local/admin environments.
WASM_HOST_PATH=

# Transaction defaults
GAS_ADJ=1.6
DEFAULT_FEES=1000000000000000inj
